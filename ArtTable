INSERT [int].[ArtTableLoader] ([Id], [Name], [SourceTable], [ArtTable], [SourceGenQuery], [ArtGenQuery], [LiveArtMergeSelect], [LiveArtMergeJoins], [PrimaryKeyColumn], [HasDeleteAction], [PreLoaderJoins], [SectionId]) VALUES (9, N'tblAging.Bill_I', NULL, N'tblAging.Bill', N'select 
rb.Id SyncId
, cast (rb.StartDate as date) StartDate
, cast (rb.EndDate as date) EndDate
, cast (rb.TransactionDate as date) TransactionDate
, rb.ResidentId ResId
, PayorId
, ''I'' ServiceType
, nvPayType.ShortDescription PayType
, '''' TherapyType
, du.Code Du
, b.Amt Balance 
into [source].[tblAging.Bill_I]
from ##ResidentBills rb
 left join ##ResourceValues nvPayType on rb.TypeId = nvPayType.Id
 left join ##DistinctUnits du on du.Id = rb.DistinctUnitId 
left join ##Residents r on rb.ResidentId = r.Id 
left join ##BillableEntities pay on pay.Id = rb.PayorId
 join (
select Id, sum(Gross) Amt
 from(
select rb.Id, Gross
from ##ResidentBills rb
where 1=1
 and rb.ParentBillId is null
 and rb.Deleted = 0

 union all
 
select rb.Id, -rb.Gross 
from ##ResidentBills rb
where 1=1
AND rb.VoidedDate IS NOT NULL
and rb.ParentBillId is null
and rb.Deleted = 0

union all

select rb.ParentBillId Id, rb.Gross 
from ##ResidentBills rb
where 1=1
and rb.ParentBillId is not null
AND rb.VoidedDate IS NULL
and rb.Deleted = 0
) a
group by Id) b on b.Id = rb.Id
where 1=1
and rb.ParentBillId is null
and rb.Deleted = 0', N'select bill.SyncId, StartDate, EndDate
, cast (TransactionDate as date) TransactionDate
, r.SyncId ResId, p.SyncId PayorId
, nvServiceType.Abbreviation ServiceType, nvPayType.Abbreviation PayType
, '''' TherapyType, nvDu.Name Du, bill.Balance
, bill.Deleted
into [target].[tblAging.Bill_I]
from [art].[tblAging.Bill] bill
join [art].tblResident r on bill.ResId = r.Id
join [art].tblPayor p on p.Id = bill.PayorId
join [art].tblNameValue nvServiceType on nvServiceType.Id = bill.ServiceTypeId
join [art].tblNameValue nvPayType on nvPayType.Id = bill.PayTypeId
join [art].tblFacDistinctUnit du on du.Id = bill.FacDuId
join [art].tblNameValue nvDu on nvDu.Id = du.DuNvId
join [art].tblPhysicalEntity pe on r.PeId = pe.Id
join [target].tblPhysicalEntity peInt on pe.SyncId = peInt.SyncId
where 1=1
and nvServiceType.Abbreviation = ''I''
and bill.SyncId is not null', N'select mainTable.SyncId, mainTable.StartDate, mainTable.EndDate, mainTable.TransactionDate, r.Id ResId, p.Id PayorId
, nvST.Id ServiceTypeId, nvPT.Id PayTypeId, mainTable.TherapyType, du.Id FacDuId, mainTable.Balance, mainTable.Deleted', N'join [xtrack].dbo.tblResident r on r.SyncId = mainTable.ResId
join [xtrack].dbo.tblPayor p on p.SyncId = mainTable.PayorId
join [xtrack].dbo.tblNameValue nvST on nvST.Abbreviation = mainTable.ServiceType 
join [xtrack].dbo.tblNameValue nvPT on nvPT.Abbreviation = mainTable.PayType 
join [xtrack].dbo.tblNameValue nvDu on nvDu.Name = mainTable.Du
join [xtrack].dbo.tblFacDistinctUnit du on nvDu.Id = du.DuNvId and du.PeId = r.PeId
', N'SyncId', 1, N'join [art].tblResident t on t.Id = mainTable.ResId', 3)
GO
INSERT [int].[ArtTableLoader] ([Id], [Name], [SourceTable], [ArtTable], [SourceGenQuery], [ArtGenQuery], [LiveArtMergeSelect], [LiveArtMergeJoins], [PrimaryKeyColumn], [HasDeleteAction], [PreLoaderJoins], [SectionId]) VALUES (10, N'tblAging.Bill_A', NULL, N'tblAging.Bill', N'select   
  rb.Id SyncId
, cast (rb.StartDate as date) StartDate
, cast (rb.EndDate as date) EndDate
, cast (rb.TransactionDate as date) TransactionDate
, rb.ResidentId ResId
, PayorId
, ''A'' ServiceType
, nvPayType.ShortDescription PayType
, rb.ServiceDescription TherapyType
, du.Code Du
, b.Amt Balance
into [source].[tblAging.Bill_A]
from ##ResidentAncillaryBills rb
left join ##ResourceValues nvPayType on rb.TypeId = nvPayType.Id
left join ##DistinctUnits du on du.Id = rb.DistinctUnitId
left join ##Residents r on rb.ResidentId = r.Id
left join ##BillableEntities pay on pay.Id = rb.PayorId
join (
select Id, sum(Gross) Amt
from(
select rb.Id, Gross
from ##ResidentAncillaryBills rb
join ##ResourceValues rvServiceType on rvServiceType.Id = rb.PartABid
where 1=1
and rb.ParentBillId is null
and rvServiceType.ShortDescription = ''PARTB''

union all

select rb.Id, -rb.Gross 
from ##ResidentAncillaryBills rb
join ##ResourceValues rvServiceType on rvServiceType.Id = rb.PartABid
where 1=1
AND rb.VoidedDate IS NOT NULL
and rvServiceType.ShortDescription = ''PARTB''
and rb.ParentBillId is null

union all

select rb.ParentBillId Id, rb.Gross 
from ##ResidentAncillaryBills rb
join ##ResourceValues rvServiceType on rvServiceType.Id = rb.PartABid
where 1=1
and rb.ParentBillId is not null
and rvServiceType.ShortDescription = ''PARTB''
AND rb.VoidedDate IS NULL
) a
group by Id) b on b.Id = rb.Id
where 1=1
and rb.ParentBillId is null
and rb.WriteOff = 0
and rb.Deleted = 0', N'select bill.SyncId, StartDate, EndDate
, cast (TransactionDate as date) TransactionDate
, r.SyncId ResId, p.SyncId PayorId
, nvServiceType.Abbreviation ServiceType, nvPayType.Abbreviation PayType
, bill.TherapyType, nvDu.Name Du, bill.Balance
, bill.Deleted
into [target].[tblAging.Bill_A]
from [art].[tblAging.Bill] bill
join [art].tblResident r on bill.ResId = r.Id
join [art].tblPayor p on p.Id = bill.PayorId
left join [art].tblNameValue nvServiceType on nvServiceType.Id = bill.ServiceTypeId
join [art].tblNameValue nvPayType on nvPayType.Id = bill.PayTypeId
join [art].tblFacDistinctUnit du on du.Id = bill.FacDuId
join [art].tblNameValue nvDu on nvDu.Id = du.DuNvId
join [art].tblPhysicalEntity pe on r.PeId = pe.Id
join [target].tblPhysicalEntity peInt on pe.SyncId = peInt.SyncId
where 1=1
and nvServiceType.Abbreviation = ''A''
and bill.SyncId is not null', N'select mainTable.SyncId, mainTable.StartDate, mainTable.EndDate, mainTable.TransactionDate, r.Id ResId, p.Id PayorId
